{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "nishant-portfolio-five.vercel.app"
        }
      ],
      "destination": "https://www.nishantsharmaa.in/$1",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "nishantsharmaa.in"
        }
      ],
      "destination": "https://www.nishantsharmaa.in/:path*",
      "permanent": true
    }
  ]
}
